# SECURITY: Sensitive Configuration Files
# ============================================

# Server credentials and configuration
scripts/config.sh
scripts/*.local.sh
scripts/*-local.sh
ansible/inventory.yml
ansible/.vault-password-file
ansible/vault.yml
ansible/*.vault
config.local.*
*.credentials
*.secrets

# Environment files
.env
.env.*
!.env.example

