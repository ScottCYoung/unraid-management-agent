*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks
*.keystore
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
*.pub
known_hosts

# Auth / secret files
.htpasswd
.htaccess
*.token
*.apikey

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files that might contain sensitive data
*.bak
*.backup
*.orig

