$plugin      = "unraid-management-agent";
$config_file = "/boot/config/plugins/$plugin/config.cfg";

$config = [];
if (file_exists($config_file)) {
    $config = parse_ini_file($config_file, false, INI_SCANNER_RAW);
}

// ── Core ──────────────────────────────────────────────────────────────────────
$port               = $config['PORT']               ?? '8043';
$log_level          = $config['LOG_LEVEL']          ?? 'info';
$cors_origin        = $config['CORS_ORIGIN']        ?? '*';
$low_power_mode     = $config['LOW_POWER_MODE']     ?? 'false';
$disable_collectors = $config['DISABLE_COLLECTORS'] ?? '';
$read_only_mode     = $config['READ_ONLY_MODE']     ?? 'false';

// ── Watchdog ──────────────────────────────────────────────────────────────────
$watchdog_enabled  = $config['WATCHDOG_ENABLED']  ?? 'false';
$watchdog_interval = $config['WATCHDOG_INTERVAL'] ?? '5';

// ── MQTT ──────────────────────────────────────────────────────────────────────
$mqtt_enabled              = $config['MQTT_ENABLED']              ?? 'false';
$mqtt_broker               = $config['MQTT_BROKER']               ?? '';
$mqtt_port                 = $config['MQTT_PORT']                 ?? '1883';
$mqtt_username             = $config['MQTT_USERNAME']             ?? '';
$mqtt_password             = $config['MQTT_PASSWORD']             ?? '';
$mqtt_client_id            = $config['MQTT_CLIENT_ID']            ?? 'unraid-management-agent';
$mqtt_topic_prefix         = $config['MQTT_TOPIC_PREFIX']         ?? 'unraid';
$mqtt_ha_enabled           = $config['MQTT_HOME_ASSISTANT']       ?? 'false';
$mqtt_ha_prefix            = $config['MQTT_HA_PREFIX']            ?? 'homeassistant';
$mqtt_use_tls              = $config['MQTT_USE_TLS']              ?? 'false';
$mqtt_insecure_skip_verify = $config['MQTT_INSECURE_SKIP_VERIFY'] ?? 'false';
$mqtt_qos                  = $config['MQTT_QOS']                  ?? '0';
$mqtt_retain               = $config['MQTT_RETAIN']               ?? 'true';

// ── Collection intervals ──────────────────────────────────────────────────────
$interval_system       = $config['INTERVAL_SYSTEM']       ?? '15';
$interval_array        = $config['INTERVAL_ARRAY']        ?? '60';
$interval_disk         = $config['INTERVAL_DISK']         ?? '300';
$interval_network      = $config['INTERVAL_NETWORK']      ?? '60';
$interval_docker       = $config['INTERVAL_DOCKER']       ?? '30';
$interval_vm           = $config['INTERVAL_VM']           ?? '60';
$interval_gpu          = $config['INTERVAL_GPU']          ?? '60';
$interval_ups          = $config['INTERVAL_UPS']          ?? '60';
$interval_nut          = $config['INTERVAL_NUT']          ?? '0';
$interval_hardware     = $config['INTERVAL_HARDWARE']     ?? '600';
$interval_shares       = $config['INTERVAL_SHARES']       ?? '60';
$interval_zfs          = $config['INTERVAL_ZFS']          ?? '0';
$interval_unassigned   = $config['INTERVAL_UNASSIGNED']   ?? '60';
$interval_notification = $config['INTERVAL_NOTIFICATION'] ?? '30';
$interval_registration = $config['INTERVAL_REGISTRATION'] ?? '600';
$interval_fan_control  = $config['INTERVAL_FAN_CONTROL']  ?? '5';
$interval_tuning       = $config['INTERVAL_TUNING']       ?? '120';

// ── Service status ────────────────────────────────────────────────────────────
exec("pidof $plugin 2>/dev/null", $pid_arr, $pid_rc);
$running = ($pid_rc === 0 && !empty($pid_arr));
$pid     = $running ? (int)explode(' ', trim($pid_arr[0]))[0] : 0;

$uptime_str = 'N/A';
if ($running && $pid > 0) {
    exec("ps -o etimes= -p $pid 2>/dev/null", $etimes_out);
    if (!empty($etimes_out)) {
        $secs       = (int)trim($etimes_out[0]);
        $d          = (int)($secs / 86400);
        $h          = (int)(($secs % 86400) / 3600);
        $m          = (int)(($secs % 3600) / 60);
        $uptime_str = ($d > 0 ? "{$d}d " : '') . "{$h}h {$m}m";
    }
}

$version  = 'Unknown';
$ver_files = [
    "/usr/local/emhttp/plugins/$plugin/VERSION",
    "/usr/local/emhttp/plugins/$plugin/version.txt",
];
foreach ($ver_files as $vf) {
    if (file_exists($vf) && ($v = trim(file_get_contents($vf))) !== '') {
        $version = $v;
        break;
    }
}
$version = htmlspecialchars($version, ENT_QUOTES, 'UTF-8');

// ── Crash log ─────────────────────────────────────────────────────────────────
$crash_log   = "/var/log/$plugin-crash.log";
$crash_count = 0;
$last_crash  = '';
if (file_exists($crash_log)) {
    foreach (file($crash_log, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (stripos($line, 'not running') !== false) {
            $crash_count++;
            $last_crash = substr(trim($line), 0, 19);
        }
    }
}

// ── Endpoint construction ─────────────────────────────────────────────────────
$raw_addr = $_SERVER['SERVER_ADDR'] ?? '127.0.0.1';
$addr_esc = htmlspecialchars(
    (strpos($raw_addr, ':') !== false) ? "[$raw_addr]" : $raw_addr,
    ENT_QUOTES, 'UTF-8'
);
$port_esc = htmlspecialchars($port, ENT_QUOTES, 'UTF-8');
$base_url = "http://{$addr_esc}:{$port_esc}";

// ── Collector enable state ────────────────────────────────────────────────────
$disabled_arr = array_filter(array_map('trim', explode(',', $disable_collectors)));
function isCollectorEnabled($name, $disabled_arr) {
    return !in_array(strtolower($name), array_map('strtolower', $disabled_arr));
}

// ── Interval select helper ────────────────────────────────────────────────────
function intervalOptions($selected, $type = 'standard') {
    $extended = [
        '3600'  => '1 hour',   '7200'  => '2 hours',
        '14400' => '4 hours',  '21600' => '6 hours',
        '43200' => '12 hours', '86400' => '24 hours',
    ];
    if ($type === 'fast') {
        $base = ['0'=>'Disabled','5'=>'5 seconds','10'=>'10 seconds','15'=>'15 seconds',
                 '30'=>'30 seconds','60'=>'1 minute','120'=>'2 minutes','300'=>'5 minutes',
                 '600'=>'10 minutes','900'=>'15 minutes','1800'=>'30 minutes'];
    } elseif ($type === 'slow') {
        $base = ['0'=>'Disabled','60'=>'1 minute','120'=>'2 minutes','300'=>'5 minutes',
                 '600'=>'10 minutes','900'=>'15 minutes','1800'=>'30 minutes'];
    } else {
        $base = ['0'=>'Disabled','10'=>'10 seconds','15'=>'15 seconds','30'=>'30 seconds',
                 '60'=>'1 minute','120'=>'2 minutes','300'=>'5 minutes',
                 '600'=>'10 minutes','900'=>'15 minutes','1800'=>'30 minutes'];
    }
    $html = '';
    foreach (array_merge($base, $extended) as $val => $label) {
        $sel   = ((string)$selected === (string)$val) ? ' selected' : '';
        $html .= "<option value=\"{$val}\"{$sel}>{$label}</option>";
    }
    return $html;
}

// ── Log tail ──────────────────────────────────────────────────────────────────
exec("tail -20 /var/log/$plugin.log 2>/dev/null", $log_lines);
$log_tail = !empty($log_lines)
    ? htmlspecialchars(implode("\n", $log_lines), ENT_QUOTES, 'UTF-8')
    : 'No log entries yet.';
?>

