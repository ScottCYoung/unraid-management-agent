// ── Collector toggles → DISABLE_COLLECTORS ────────────────────────────────
function rebuildDisableCollectors() {
    var disabled = [];
    document.querySelectorAll('.collector-toggle').forEach(function(cb) {
        if (!cb.checked) disabled.push(cb.dataset.collector);
    });
    document.getElementById('disable_collectors_input').value = disabled.join(',');
}

// ── Copy to clipboard ──────────────────────────────────────────────────────
function umaCopy(elemId, btn) {
    var text = document.getElementById(elemId).innerText;
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
            var orig = btn.value; btn.value = 'Copied!';
            setTimeout(function() { btn.value = orig; }, 1500);
        });
    } else {
        var ta = document.createElement('textarea');
        ta.value = text; document.body.appendChild(ta);
        ta.select(); document.execCommand('copy');
        document.body.removeChild(ta);
        var orig = btn.value; btn.value = 'Copied!';
        setTimeout(function() { btn.value = orig; }, 1500);
    }
}

// ── Connections modal ─────────────────────────────────────────────────────
function openConnModal()  { document.getElementById('uma-conn-modal').classList.add('open'); document.getElementById('uma-conn-backdrop').classList.add('open'); }
function closeConnModal() { document.getElementById('uma-conn-modal').classList.remove('open'); document.getElementById('uma-conn-backdrop').classList.remove('open'); }

// ── Log refresh ───────────────────────────────────────────────────────────
function refreshLog() {
    $.get('/plugins/<?= $plugin ?>/include/exec.php', {action:'log'}, function(data) {
        if (data && data.log) document.getElementById('uma-log-content').textContent = data.log;
    }, 'json').fail(function() { location.reload(); });
}

// ── Init ───────────────────────────────────────────────────────────────────
$(function() {
    document.querySelectorAll('.collector-toggle').forEach(function(cb) {
        cb.addEventListener('change', function() {
            var sel = this.closest('.uma-collector-row').querySelector('select');
            if (sel) sel.disabled = !this.checked;
            rebuildDisableCollectors();
            $('input[name="#apply"]').prop('disabled', false);
        });
    });
    $('#agentConfigForm').on('change input', 'input:not(.collector-toggle), select', function() {
        $('input[name="#apply"]').prop('disabled', false);
    });
});
</script>
