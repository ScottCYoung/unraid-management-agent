#!/bin/bash
PLUGIN="unraid-management-agent"
CONFIG_FILE="/boot/config/plugins/$PLUGIN/config.cfg"
PROG="/usr/local/emhttp/plugins/$PLUGIN/$PLUGIN"
LOGS_DIR="/var/log"
CRON_FILE="/etc/cron.d/$PLUGIN-watchdog"

# Create config directory if it doesn't exist
mkdir -p /boot/config/plugins/$PLUGIN

# Create default config file if it doesn't exist
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" << 'EOF'
PORT="8043"
EOF
fi

# Read configuration
source "$CONFIG_FILE"

# Stop any existing instance
killall $PLUGIN >/dev/null 2>&1

# ── Core ────────────────────────────────────────────────────
PORT="${PORT:-8043}"
LOG_LEVEL="${LOG_LEVEL:-info}"
CORS_ORIGIN="${CORS_ORIGIN:-*}"
LOW_POWER_MODE="${LOW_POWER_MODE:-false}"
DISABLE_COLLECTORS="${DISABLE_COLLECTORS:-}"
READ_ONLY_MODE="${READ_ONLY_MODE:-false}"

# ── Collection intervals ─────────────────────────────────────
INTERVAL_SYSTEM="${INTERVAL_SYSTEM:-15}"
INTERVAL_ARRAY="${INTERVAL_ARRAY:-60}"
INTERVAL_DISK="${INTERVAL_DISK:-300}"
INTERVAL_DOCKER="${INTERVAL_DOCKER:-30}"
INTERVAL_VM="${INTERVAL_VM:-60}"
INTERVAL_UPS="${INTERVAL_UPS:-60}"
INTERVAL_NUT="${INTERVAL_NUT:-0}"
INTERVAL_GPU="${INTERVAL_GPU:-60}"
INTERVAL_SHARES="${INTERVAL_SHARES:-60}"
INTERVAL_NETWORK="${INTERVAL_NETWORK:-60}"
INTERVAL_HARDWARE="${INTERVAL_HARDWARE:-600}"
INTERVAL_ZFS="${INTERVAL_ZFS:-0}"
INTERVAL_UNASSIGNED="${INTERVAL_UNASSIGNED:-60}"
INTERVAL_NOTIFICATION="${INTERVAL_NOTIFICATION:-30}"
INTERVAL_REGISTRATION="${INTERVAL_REGISTRATION:-600}"
INTERVAL_FAN_CONTROL="${INTERVAL_FAN_CONTROL:-5}"
INTERVAL_TUNING="${INTERVAL_TUNING:-120}"

# ── MQTT ─────────────────────────────────────────────────────
MQTT_ENABLED="${MQTT_ENABLED:-false}"
MQTT_BROKER="${MQTT_BROKER:-}"
MQTT_PORT="${MQTT_PORT:-1883}"
MQTT_USERNAME="${MQTT_USERNAME:-}"
MQTT_PASSWORD="${MQTT_PASSWORD:-}"
MQTT_CLIENT_ID="${MQTT_CLIENT_ID:-unraid-management-agent}"
MQTT_TOPIC_PREFIX="${MQTT_TOPIC_PREFIX:-unraid}"
MQTT_HOME_ASSISTANT="${MQTT_HOME_ASSISTANT:-false}"
MQTT_HA_PREFIX="${MQTT_HA_PREFIX:-homeassistant}"
MQTT_USE_TLS="${MQTT_USE_TLS:-false}"
MQTT_INSECURE_SKIP_VERIFY="${MQTT_INSECURE_SKIP_VERIFY:-false}"
MQTT_QOS="${MQTT_QOS:-0}"
MQTT_RETAIN="${MQTT_RETAIN:-true}"

# ── Input validation helpers ──────────────────────────────────
# Strip anything that isn't a digit
sanitize_int() { echo "$1" | tr -cd '0-9'; }
# Strip anything that isn't alphanumeric, comma, or hyphen
sanitize_csv() { echo "$1" | tr -cd 'a-zA-Z0-9,_-'; }
# Strip shell metacharacters from freeform strings
sanitize_str() { echo "$1" | tr -d "'\"\`\$\\"; }
# Validate boolean: only "true" passes, everything else is "false"
sanitize_bool() { [ "$1" = "true" ] && echo "true" || echo "false"; }

# ── Sanitize all config values ───────────────────────────────
PORT=$(sanitize_int "$PORT");                     PORT="${PORT:-8043}"
LOG_LEVEL=$(echo "$LOG_LEVEL" | grep -xE 'debug|info|warning|error' || echo "info")
CORS_ORIGIN=$(sanitize_str "$CORS_ORIGIN");       CORS_ORIGIN="${CORS_ORIGIN:-*}"
LOW_POWER_MODE=$(sanitize_bool "$LOW_POWER_MODE")
READ_ONLY_MODE=$(sanitize_bool "$READ_ONLY_MODE")
DISABLE_COLLECTORS=$(sanitize_csv "$DISABLE_COLLECTORS")

INTERVAL_SYSTEM=$(sanitize_int "$INTERVAL_SYSTEM")
INTERVAL_ARRAY=$(sanitize_int "$INTERVAL_ARRAY")
INTERVAL_DISK=$(sanitize_int "$INTERVAL_DISK")
INTERVAL_DOCKER=$(sanitize_int "$INTERVAL_DOCKER")
INTERVAL_VM=$(sanitize_int "$INTERVAL_VM")
INTERVAL_UPS=$(sanitize_int "$INTERVAL_UPS")
INTERVAL_NUT=$(sanitize_int "$INTERVAL_NUT")
INTERVAL_GPU=$(sanitize_int "$INTERVAL_GPU")
INTERVAL_SHARES=$(sanitize_int "$INTERVAL_SHARES")
INTERVAL_NETWORK=$(sanitize_int "$INTERVAL_NETWORK")
INTERVAL_HARDWARE=$(sanitize_int "$INTERVAL_HARDWARE")
INTERVAL_ZFS=$(sanitize_int "$INTERVAL_ZFS")
INTERVAL_UNASSIGNED=$(sanitize_int "$INTERVAL_UNASSIGNED")
INTERVAL_NOTIFICATION=$(sanitize_int "$INTERVAL_NOTIFICATION")
INTERVAL_REGISTRATION=$(sanitize_int "$INTERVAL_REGISTRATION")
INTERVAL_FAN_CONTROL=$(sanitize_int "$INTERVAL_FAN_CONTROL")
INTERVAL_TUNING=$(sanitize_int "$INTERVAL_TUNING")

MQTT_ENABLED=$(sanitize_bool "$MQTT_ENABLED")
MQTT_BROKER=$(sanitize_str "$MQTT_BROKER")
MQTT_PORT=$(sanitize_int "$MQTT_PORT");           MQTT_PORT="${MQTT_PORT:-1883}"
MQTT_USERNAME=$(sanitize_str "$MQTT_USERNAME")
MQTT_PASSWORD=$(sanitize_str "$MQTT_PASSWORD")
MQTT_CLIENT_ID=$(sanitize_str "$MQTT_CLIENT_ID")
MQTT_TOPIC_PREFIX=$(sanitize_str "$MQTT_TOPIC_PREFIX")
MQTT_HOME_ASSISTANT=$(sanitize_bool "$MQTT_HOME_ASSISTANT")
MQTT_HA_PREFIX=$(sanitize_str "$MQTT_HA_PREFIX")
MQTT_USE_TLS=$(sanitize_bool "$MQTT_USE_TLS")
MQTT_INSECURE_SKIP_VERIFY=$(sanitize_bool "$MQTT_INSECURE_SKIP_VERIFY")
MQTT_QOS=$(sanitize_int "$MQTT_QOS")
MQTT_RETAIN=$(sanitize_bool "$MQTT_RETAIN")

# ── Watchdog cron ─────────────────────────────────────────────
WATCHDOG_ENABLED=$(sanitize_bool "$WATCHDOG_ENABLED")
WATCHDOG_INTERVAL=$(sanitize_int "$WATCHDOG_INTERVAL")
# Clamp to allowed values; default 5
case "$WATCHDOG_INTERVAL" in
    1|2|5|10|15|30) ;;
    *) WATCHDOG_INTERVAL=5 ;;
esac

if [ "$WATCHDOG_ENABLED" = "true" ]; then
    echo "*/$WATCHDOG_INTERVAL * * * * root /usr/local/emhttp/plugins/$PLUGIN/scripts/watchdog" > "$CRON_FILE"
    /usr/bin/killall -HUP crond 2>/dev/null || true
else
    rm -f "$CRON_FILE"
    /usr/bin/killall -HUP crond 2>/dev/null || true
fi

# ── Build extra CLI flags ─────────────────────────────────────
EXTRA_FLAGS=""
[ "$LOW_POWER_MODE" = "true" ] && EXTRA_FLAGS="$EXTRA_FLAGS --low-power-mode"
[ -n "$DISABLE_COLLECTORS" ]   && EXTRA_FLAGS="$EXTRA_FLAGS --disable-collectors $DISABLE_COLLECTORS"
[ "$READ_ONLY_MODE" = "true" ] && EXTRA_FLAGS="$EXTRA_FLAGS --read-only"

# ── Launch ────────────────────────────────────────────────────
# Use env(1) to pass variables safely instead of shell interpolation
nohup env \
  CORS_ORIGIN="$CORS_ORIGIN" \
  UNRAID_LOW_POWER="$LOW_POWER_MODE" \
  UNRAID_DISABLE_COLLECTORS="$DISABLE_COLLECTORS" \
  INTERVAL_SYSTEM="$INTERVAL_SYSTEM" \
  INTERVAL_ARRAY="$INTERVAL_ARRAY" \
  INTERVAL_DISK="$INTERVAL_DISK" \
  INTERVAL_DOCKER="$INTERVAL_DOCKER" \
  INTERVAL_VM="$INTERVAL_VM" \
  INTERVAL_UPS="$INTERVAL_UPS" \
  INTERVAL_NUT="$INTERVAL_NUT" \
  INTERVAL_GPU="$INTERVAL_GPU" \
  INTERVAL_SHARES="$INTERVAL_SHARES" \
  INTERVAL_NETWORK="$INTERVAL_NETWORK" \
  INTERVAL_HARDWARE="$INTERVAL_HARDWARE" \
  INTERVAL_ZFS="$INTERVAL_ZFS" \
  INTERVAL_UNASSIGNED="$INTERVAL_UNASSIGNED" \
  INTERVAL_NOTIFICATION="$INTERVAL_NOTIFICATION" \
  INTERVAL_REGISTRATION="$INTERVAL_REGISTRATION" \
  INTERVAL_FAN_CONTROL="$INTERVAL_FAN_CONTROL" \
  INTERVAL_TUNING="$INTERVAL_TUNING" \
  MQTT_ENABLED="$MQTT_ENABLED" \
  MQTT_BROKER="$MQTT_BROKER" \
  MQTT_PORT="$MQTT_PORT" \
  MQTT_USERNAME="$MQTT_USERNAME" \
  MQTT_PASSWORD="$MQTT_PASSWORD" \
  MQTT_CLIENT_ID="$MQTT_CLIENT_ID" \
  MQTT_TOPIC_PREFIX="$MQTT_TOPIC_PREFIX" \
  MQTT_HOME_ASSISTANT="$MQTT_HOME_ASSISTANT" \
  MQTT_HA_PREFIX="$MQTT_HA_PREFIX" \
  MQTT_USE_TLS="$MQTT_USE_TLS" \
  MQTT_INSECURE_SKIP_VERIFY="$MQTT_INSECURE_SKIP_VERIFY" \
  MQTT_QOS="$MQTT_QOS" \
  MQTT_RETAIN="$MQTT_RETAIN" \
  "$PROG" --logs-dir "$LOGS_DIR" --port "$PORT" --log-level "$LOG_LEVEL" $EXTRA_FLAGS boot \
  >/dev/null 2>&1 &

echo "$PLUGIN started on port $PORT"
