.uma-log-pre { background: #111; color: #ccc; font-family: monospace; font-size: 10px; padding: 8px; border-radius: 4px; overflow-y: auto; white-space: pre-wrap; word-wrap: break-word; border: 1px solid #333; margin: 0; max-height: 400px; }
.uma-log-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
