.uma-conn-code { font-family: monospace; font-size: 10px; background: rgba(0,0,0,0.25); padding: 4px 8px; border-radius: 3px; word-break: break-all; flex: 1; color: var(--text-color,#ccc); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.uma-conn-code:hover { white-space: normal; }
.uma-copy-btn { padding: 2px 8px; font-size: 11px; cursor: pointer; white-space: nowrap; }

/* ── Collector rows ── */
.uma-section-header { font-size: 10px; font-weight: bold; color: var(--gray-500,#777); text-transform: uppercase; letter-spacing: 0.5px; margin: 8px 0 4px; padding-top: 6px; border-top: 1px solid rgba(255,255,255,0.06); }
.uma-section-header:first-child { border-top: none; margin-top: 0; padding-top: 0; }
