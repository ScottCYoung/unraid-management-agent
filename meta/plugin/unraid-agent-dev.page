.uma-row label, .uma-row .uma-lbl { min-width: 120px; color: var(--text-secondary,#aaa); font-size: 12px; }
.uma-row input[type="text"], .uma-row input[type="number"], .uma-row input[type="password"], .uma-row select { font-size: 12px; background: var(--input-bg-color,transparent); border: 1px solid var(--input-border-color,#555); border-radius: 3px; color: var(--text-color,inherit); }
.uma-row input[type="text"], .uma-row input[type="number"], .uma-row input[type="password"] { flex: 1; padding: 3px 8px; }
