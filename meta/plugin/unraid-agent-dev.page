 * as published by the Free Software Foundation.
 */

$plugin      = "unraid-agent-dev";
$config_file = "/boot/config/plugins/$plugin/config.cfg";

$config = [];
if (file_exists($config_file)) {
    $raw = parse_ini_file($config_file, false, INI_SCANNER_RAW);
    // Unraid's update.php writes disabled form fields as empty strings.
    // Remove them so the ?? defaults below apply correctly.
    if ($raw !== false) {
        $config = array_filter($raw, function($v) { return $v !== ''; });
    }
}

// ── Core ──────────────────────────────────────────────────────────────────────
$port               = $config['PORT']               ?? '8043';
$log_level          = $config['LOG_LEVEL']          ?? 'info';
$cors_origin        = $config['CORS_ORIGIN']        ?? '*';
$low_power_mode     = $config['LOW_POWER_MODE']     ?? 'false';
$disable_collectors = $config['DISABLE_COLLECTORS'] ?? '';
$read_only_mode     = $config['READ_ONLY_MODE']     ?? 'false';

// ── Watchdog ──────────────────────────────────────────────────────────────────
$watchdog_enabled  = $config['WATCHDOG_ENABLED']  ?? 'false';
$watchdog_interval = $config['WATCHDOG_INTERVAL'] ?? '5';

// ── MQTT ──────────────────────────────────────────────────────────────────────
$mqtt_enabled              = $config['MQTT_ENABLED']              ?? 'false';
$mqtt_broker               = $config['MQTT_BROKER']               ?? '';
$mqtt_port                 = $config['MQTT_PORT']                 ?? '1883';
$mqtt_username             = $config['MQTT_USERNAME']             ?? '';
$mqtt_password             = $config['MQTT_PASSWORD']             ?? '';
$mqtt_client_id            = $config['MQTT_CLIENT_ID']            ?? 'unraid-agent-dev';
$mqtt_topic_prefix         = $config['MQTT_TOPIC_PREFIX']         ?? 'unraid';
$mqtt_ha_enabled           = $config['MQTT_HOME_ASSISTANT']       ?? 'false';
$mqtt_ha_prefix            = $config['MQTT_HA_PREFIX']            ?? 'homeassistant';
$mqtt_use_tls              = $config['MQTT_USE_TLS']              ?? 'false';
$mqtt_insecure_skip_verify = $config['MQTT_INSECURE_SKIP_VERIFY'] ?? 'false';
$mqtt_qos                  = $config['MQTT_QOS']                  ?? '0';
$mqtt_retain               = $config['MQTT_RETAIN']               ?? 'true';

// ── MQTT Embedded Broker ──────────────────────────────────────────────────────
$mqtt_embedded_broker      = $config['MQTT_EMBEDDED_BROKER']          ?? 'false';
$mqtt_embedded_broker_port = $config['MQTT_EMBEDDED_BROKER_PORT']     ?? '1883';
$mqtt_embedded_broker_bind = $config['MQTT_EMBEDDED_BROKER_BIND_ALL'] ?? 'false';
// MQTT_EMBEDDED_BROKER_PASSWORD is a secret — never echo it; only track whether one is set
$mqtt_embedded_broker_has_pw = !empty($config['MQTT_EMBEDDED_BROKER_PASSWORD']);

// ── Collection intervals ──────────────────────────────────────────────────────
$interval_system       = $config['INTERVAL_SYSTEM']       ?? '30';
$interval_array        = $config['INTERVAL_ARRAY']        ?? '60';
$interval_disk         = $config['INTERVAL_DISK']         ?? '300';
$interval_network      = $config['INTERVAL_NETWORK']      ?? '30';
$interval_docker       = $config['INTERVAL_DOCKER']       ?? '30';
$interval_vm           = $config['INTERVAL_VM']           ?? '60';
$interval_gpu          = $config['INTERVAL_GPU']          ?? '0';
$interval_ups          = $config['INTERVAL_UPS']          ?? '0';
$interval_nut          = $config['INTERVAL_NUT']          ?? '0';
$interval_hardware     = $config['INTERVAL_HARDWARE']     ?? '3600';
$interval_shares       = $config['INTERVAL_SHARES']       ?? '300';
$interval_zfs          = $config['INTERVAL_ZFS']          ?? '0';
$interval_unassigned   = $config['INTERVAL_UNASSIGNED']   ?? '300';
$interval_notification = $config['INTERVAL_NOTIFICATION'] ?? '30';
$interval_registration = $config['INTERVAL_REGISTRATION'] ?? '3600';
$interval_fan_control  = $config['INTERVAL_FAN_CONTROL']  ?? '10';
$interval_tuning       = $config['INTERVAL_TUNING']       ?? '300';

// ── Service status ────────────────────────────────────────────────────────────
exec("pidof $plugin 2>/dev/null", $pid_arr, $pid_rc);
$running = ($pid_rc === 0 && !empty($pid_arr));
$pid     = $running ? (int)explode(' ', trim($pid_arr[0]))[0] : 0;

$uptime_str = 'N/A';
if ($running && $pid > 0) {
    exec("ps -o etimes= -p $pid 2>/dev/null", $etimes_out);
    if (!empty($etimes_out)) {
        $secs       = (int)trim($etimes_out[0]);
        $d          = (int)($secs / 86400);
        $h          = (int)(($secs % 86400) / 3600);
        $m          = (int)(($secs % 3600) / 60);
        $uptime_str = ($d > 0 ? "{$d}d " : '') . "{$h}h {$m}m";
    }
}

$version  = 'Unknown';
$ver_files = [
    "/usr/local/emhttp/plugins/$plugin/VERSION",
    "/usr/local/emhttp/plugins/$plugin/version.txt",
];
foreach ($ver_files as $vf) {
    if (file_exists($vf) && ($v = trim(file_get_contents($vf))) !== '') {
        $version = $v;
        break;
    }
}
$version = htmlspecialchars($version, ENT_QUOTES, 'UTF-8');

// ── Crash log ─────────────────────────────────────────────────────────────────
$crash_log   = "/var/log/$plugin-crash.log";
$crash_count = 0;
$last_crash  = '';
if (file_exists($crash_log)) {
    foreach (file($crash_log, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (stripos($line, 'not running') !== false) {
            $crash_count++;
            $last_crash = substr(trim($line), 0, 19);
        }
    }
}

// ── Watchdog status ──────────────────────────────────────────────────────────
$heartbeat_file = "/var/run/$plugin-watchdog.heartbeat";
$last_check = '';
$heartbeat_age = 0;
if (file_exists($heartbeat_file)) {
    $heartbeat_age = time() - filemtime($heartbeat_file);
    $last_check = date('Y/m/d H:i:s', filemtime($heartbeat_file));
}
$cron_file = "/etc/cron.d/$plugin-watchdog";
$cron_active = file_exists($cron_file);

// ── Health assessment ────────────────────────────────────────────────────────
$wd_health = 'disabled';
$wd_health_msg = 'Watchdog is off. The agent will not auto-restart if it crashes.';
if ($watchdog_enabled === 'true') {
    if (!$cron_active) {
        $wd_health = 'misconfigured';
        $wd_health_msg = 'Watchdog is enabled in config but the cron job is missing. Click Apply to install it.';
    } elseif (!$last_check) {
        $wd_health = 'waiting';
        $wd_health_msg = 'Watchdog cron is installed and waiting for its first check. It will verify the agent is running every ' . (int)$watchdog_interval . ' minutes.';
    } elseif ($heartbeat_age > ((int)$watchdog_interval * 60 * 3)) {
        $wd_health = 'stale';
        $wd_health_msg = 'The watchdog has not checked in for ' . round($heartbeat_age / 60) . ' minutes. Cron may not be running. Check system logs.';
    } else {
        $wd_health = 'healthy';
        $wd_health_msg = 'Watchdog is actively monitoring. It verified the agent was running ' . ($heartbeat_age < 120 ? 'just now' : round($heartbeat_age / 60) . ' minutes ago') . '. If the agent crashes, it will be restarted within ' . (int)$watchdog_interval . ' minutes.';
    }
    if ($crash_count > 0) {
        $wd_health_msg .= ' ' . (int)$crash_count . ' crash' . ($crash_count != 1 ? 'es' : '') . ' detected since last boot.';
    }
}

$agent_health_msg = '';
if ($running) {
    $agent_health_msg = 'The agent is running and serving all enabled endpoints. ';
    if ((int)$secs < 300) {
        $agent_health_msg .= 'It started recently — if you see repeated short uptimes, the agent may be crashing and restarting. Check the crash log.';
    } elseif ((int)$secs > 86400) {
        $agent_health_msg .= 'Uptime is over ' . (int)($secs / 86400) . ' day' . ((int)($secs / 86400) != 1 ? 's' : '') . ' — stable.';
    } else {
        $agent_health_msg .= 'Uptime looks healthy.';
    }
} else {
    $agent_health_msg = 'The agent is not running. All API endpoints, WebSocket, MCP, and Prometheus metrics are offline. Click Start to launch it.';
}

// ── Endpoint construction ─────────────────────────────────────────────────────
$raw_addr = $_SERVER['SERVER_ADDR'] ?? '127.0.0.1';
$addr_esc = htmlspecialchars(
    (strpos($raw_addr, ':') !== false) ? "[$raw_addr]" : $raw_addr,
    ENT_QUOTES, 'UTF-8'
);
$port_esc = htmlspecialchars($port, ENT_QUOTES, 'UTF-8');
$base_url = "http://{$addr_esc}:{$port_esc}";

// ── Collector enable state ────────────────────────────────────────────────────
// A collector is disabled if it's in the DISABLE_COLLECTORS list OR its interval is 0
$disabled_arr = array_filter(array_map('trim', explode(',', $disable_collectors)));
$interval_map = [
    'system'=>$interval_system, 'array'=>$interval_array, 'disk'=>$interval_disk,
    'network'=>$interval_network, 'docker'=>$interval_docker, 'vm'=>$interval_vm,
    'gpu'=>$interval_gpu, 'ups'=>$interval_ups, 'nut'=>$interval_nut,
    'hardware'=>$interval_hardware, 'shares'=>$interval_shares, 'zfs'=>$interval_zfs,
    'unassigned'=>$interval_unassigned,
];
function isCollectorEnabled($name, $disabled_arr) {
    global $interval_map;
    $lname = strtolower($name);
    if (in_array($lname, array_map('strtolower', $disabled_arr))) return false;
    if (isset($interval_map[$lname]) && $interval_map[$lname] === '0') return false;
    return true;
}
// Rebuild disabled_arr to include interval=0 collectors (sync for hidden input)
foreach ($interval_map as $cname => $ival) {
    if ($ival === '0' && !in_array($cname, $disabled_arr)) {
        $disabled_arr[] = $cname;
    }
}
$disable_collectors = implode(',', $disabled_arr);

// ── Interval select helper ────────────────────────────────────────────────────
function intervalOptions($selected, $type = 'standard') {
    $extended = [
        '3600'  => '1 hour',   '7200'  => '2 hours',
        '14400' => '4 hours',  '21600' => '6 hours',
        '43200' => '12 hours', '86400' => '24 hours',
    ];
    if ($type === 'fast') {
        $base = ['0'=>'Disabled','5'=>'5 seconds','10'=>'10 seconds','15'=>'15 seconds',
                 '30'=>'30 seconds','60'=>'1 minute','120'=>'2 minutes','300'=>'5 minutes',
                 '600'=>'10 minutes','900'=>'15 minutes','1800'=>'30 minutes'];
    } elseif ($type === 'slow') {
        $base = ['0'=>'Disabled','60'=>'1 minute','120'=>'2 minutes','300'=>'5 minutes',
                 '600'=>'10 minutes','900'=>'15 minutes','1800'=>'30 minutes'];
    } else {
        $base = ['0'=>'Disabled','10'=>'10 seconds','15'=>'15 seconds','30'=>'30 seconds',
                 '60'=>'1 minute','120'=>'2 minutes','300'=>'5 minutes',
                 '600'=>'10 minutes','900'=>'15 minutes','1800'=>'30 minutes'];
    }
    $html = '';
    foreach ($base + $extended as $val => $label) {
        $sel   = ((string)$selected === (string)$val) ? ' selected' : '';
        $html .= "<option value=\"{$val}\"{$sel}>{$label}</option>";
    }
    return $html;
}

// ── Log tail ──────────────────────────────────────────────────────────────────
exec("tail -20 /var/log/$plugin.log 2>/dev/null", $log_lines);
$log_lines = array_reverse($log_lines);
$log_raw = !empty($log_lines) ? implode("\n", $log_lines) : 'No log entries yet.';
// Convert ANSI color codes to HTML spans, escape everything else
$log_escaped = htmlspecialchars($log_raw, ENT_QUOTES, 'UTF-8');
$ansi_map = [
    '31' => '#f44',    // red
    '32' => '#4CAF50', // green
    '33' => '#ff8c00', // yellow/orange
    '34' => '#6cf',    // blue
    '35' => '#c084fc', // magenta
    '36' => '#67e8f9', // cyan
];
$log_tail = preg_replace_callback('/\x1b\[([0-9;]*)m/', function($m) use ($ansi_map) {
    $code = $m[1];
    if ($code === '0' || $code === '') return '</span>';
    return isset($ansi_map[$code]) ? '<span style="color:'.$ansi_map[$code].'">' : '';
}, $log_escaped);
?>

<style>
