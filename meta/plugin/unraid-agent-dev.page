<!-- ── PERSISTENT HEADER BAR ──────────────────────────────────────────────── -->
<div id="uma-header">
    <i id="uma-status-orb" class="fa fa-circle uma-orb <?= $running ? 'on' : 'off' ?>"></i>
    <span id="uma-status-text" class="uma-hdr-status <?= $running ? 'running' : 'stopped' ?>" title="<?= $running ? 'The agent is serving the REST API, WebSocket, MCP, and Prometheus endpoints on port '.$port_esc : 'The agent process is not running. Click Start to launch it.' ?>"><?= $running ? 'RUNNING' : 'STOPPED' ?></span>
    <?php if ($running): ?>
        <span style="font-size:10px;color:var(--text-secondary,#888);">port <?= $port_esc ?> &middot; <?= count(array_filter($interval_map, function($v) { return $v !== '0'; })) ?>/<?= count($interval_map) ?> polling</span>
    <?php endif; ?>

    <div id="uma-hdr-meta" class="uma-hdr-meta" style="display:<?= $running ? 'flex' : 'none' ?>;">
        <span>Uptime: <strong id="uma-uptime" data-secs="<?= $running ? (int)$secs : 0 ?>"><?= htmlspecialchars($uptime_str, ENT_QUOTES, 'UTF-8') ?></strong></span>
        <span>v<strong><?= $version ?></strong></span>
        <span>Crashes: <strong><?= (int)$crash_count ?></strong></span>
    </div>

    <div class="uma-hdr-actions">
        <button type="button" class="uma-hdr-btn" onclick="openConnModal()" title="Connection snippets"><i class="fa fa-plug"></i> Connect</button>
