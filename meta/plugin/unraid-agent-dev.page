.uma-hdr-actions input[type="button"] { padding: 3px 12px; font-size: 12px; }
.uma-hdr-btn { padding: 3px 10px; font-size: 11px; cursor: pointer; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: var(--text-color,#ccc); }
