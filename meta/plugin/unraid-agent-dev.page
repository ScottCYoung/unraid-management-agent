<script>
// ── Tab switching ──────────────────────────────────────────────────────────
$(function() {
    $('#uma-tabs .uma-tab').on('click', function() {
        var target = $(this).data('tab');
        $('#uma-tabs .uma-tab').removeClass('active');
        $(this).addClass('active');
        $('.uma-panel').removeClass('active');
        $('#' + target).addClass('active');
    });
});

// ── Service control ────────────────────────────────────────────────────────
function serviceControl(action) {
    var btn     = document.getElementById('uma-btn-startstop');
    var restart = document.getElementById('uma-btn-restart');
    btn.disabled = restart.disabled = true;
    var labels = {stop: 'Stopping…', start: 'Starting…', restart: 'Restarting…'};
    btn.value = labels[action] || 'Working…';
    $.post('/plugins/<?= $plugin ?>/include/exec.php', {action: action}, function() {
        setTimeout(pollStatus, 2500);
    }, 'json').fail(function() {
        setTimeout(pollStatus, 3000);
    });
}

function pollStatus() {
    $.post('/plugins/<?= $plugin ?>/include/exec.php', {action: 'status'}, function(data) {
        updateServiceStatus(data.running === true || data.running === 'true');
    }, 'json').fail(function() { location.reload(); });
}

function updateServiceStatus(running) {
    var orb     = document.getElementById('uma-status-orb');
    var text    = document.getElementById('uma-status-text');
    var btn     = document.getElementById('uma-btn-startstop');
    var restart = document.getElementById('uma-btn-restart');
    var meta    = document.getElementById('uma-hdr-meta');
    var ep      = document.getElementById('uma-endpoints-card');

    orb.className        = 'fa fa-circle uma-orb ' + (running ? 'on' : 'off');
    text.textContent     = running ? 'RUNNING' : 'STOPPED';
    text.className       = 'uma-hdr-status ' + (running ? 'running' : 'stopped');
    btn.value            = running ? 'Stop' : 'Start';
    btn.onclick          = running ? function(){ serviceControl('stop'); } : function(){ serviceControl('start'); };
    btn.disabled         = false;
    restart.disabled     = !running;
    if (meta) meta.style.display = running ? 'flex' : 'none';
    if (ep)   ep.style.opacity   = running ? '1'    : '0.4';
}

// ── Toggle checkbox → hidden value + field visibility ─────────────────────
function toggleSection(checkboxId, hiddenId, fieldsId) {
    var on = document.getElementById(checkboxId).checked;
    document.getElementById(hiddenId).value = on ? 'true' : 'false';
    if (fieldsId) document.getElementById(fieldsId).style.display = on ? 'block' : 'none';
}
function toggleWatchdog()   { toggleSection('watchdog_cb',     'watchdog_enabled_val', 'watchdog_fields'); }
function toggleMQTTFields() { toggleSection('mqtt_enabled_cb', 'mqtt_enabled_val',     'mqtt_fields'); }
function toggleMQTTHA()     { toggleSection('mqtt_ha_cb',      'mqtt_ha_val',          'mqtt_ha_fields'); }
function toggleMQTTTLS()    { toggleSection('mqtt_tls_cb',     'mqtt_tls_val',         'mqtt_tls_fields'); }

function toggleMQTTBrokerMode(mode) {
    var isEmbedded = (mode === 'embedded');
    document.getElementById('mqtt_embedded_val').value = isEmbedded ? 'true' : 'false';
    document.getElementById('mqtt_broker_embedded_fields').style.display = isEmbedded ? 'block' : 'none';
    document.getElementById('mqtt_broker_remote_fields').style.display   = isEmbedded ? 'none'  : 'block';
}

function toggleMQTTEBBindWarning(on) {
    document.getElementById('mqtt_eb_bind_warning').style.display = on ? 'flex' : 'none';
}

// ── MQTT live status ──────────────────────────────────────────────────────────
function fmtSecs(s) {
    s = parseInt(s) || 0;
    if (s <= 0) return '—';
    var d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60);
    return (d > 0 ? d + 'd ' : '') + (h > 0 ? h + 'h ' : '') + m + 'm';
}

// Build a stat cell using DOM methods — no innerHTML for data values
function mqttStatCell(label, value, color) {
    var cell = document.createElement('div');
    var lbl  = document.createElement('div');
    lbl.style.cssText = 'font-size:10px;color:var(--text-secondary,#888)';
    lbl.textContent = label;
    var val  = document.createElement('div');
    val.style.cssText = 'font-size:12px' + (color ? ';color:' + color : '');
    val.textContent = value;
    cell.appendChild(lbl);
    cell.appendChild(val);
    return cell;
}

function renderMQTTStatus(d) {
    var connColor = d.connected ? 'var(--green-500,#4CAF50)' : 'var(--red-500,#f44)';
    var connText  = d.connected ? 'Connected' : 'Disconnected';

    // ── Dashboard: endpoint badge ─────────────────────────────────────────
    var badge = document.getElementById('mqtt-ep-badge');
    if (badge) {
        badge.textContent  = d.connected ? 'connected' : 'disconnected';
        badge.style.color  = connColor;
        badge.style.display = 'inline';
    }
    var clientsWrap = document.getElementById('mqtt-ep-clients');
    var clientsVal  = document.getElementById('mqtt-ep-clients-val');
    if (d.embedded_broker && d.embedded_broker.enabled && clientsWrap && clientsVal) {
        clientsVal.textContent   = d.embedded_broker.client_count || 0;
        clientsWrap.style.display = 'inline';
    }

    // ── Dashboard: health row ─────────────────────────────────────────────
    var healthRow    = document.getElementById('mqtt-health-row');
    var healthBadge  = document.getElementById('mqtt-health-badge');
    var healthDetail = document.getElementById('mqtt-health-detail');
    if (healthRow) healthRow.style.display = 'block';
    if (healthBadge) {
        healthBadge.textContent = connText;
        healthBadge.style.cssText = 'font-weight:bold;color:' + connColor;
    }
    if (healthDetail) {
        var parts = [];
        if (d.messages_sent)   parts.push(parseInt(d.messages_sent).toLocaleString() + ' msgs');
        if (d.messages_errors) parts.push(d.messages_errors + ' errors');
        if (d.uptime_seconds)  parts.push('up ' + fmtSecs(d.uptime_seconds));
        healthDetail.textContent = parts.join(' · ');
        if (d.messages_errors) healthDetail.style.color = 'var(--red-500,#f44)';
    }

    // ── Advanced tab: full status panel ──────────────────────────────────
    var panel = document.getElementById('mqtt-status-content');
    if (!panel) return;

    var grid = document.createElement('div');
    grid.style.cssText = 'display:grid;grid-template-columns:repeat(3,1fr);gap:6px 16px;';

    var errColor = (d.messages_errors > 0) ? 'var(--red-500,#f44)' : null;
    var stats = [
        [connText, connColor],
        [d.broker || '—',                                           null],
        [fmtSecs(d.uptime_seconds),                                 null],
        [(parseInt(d.messages_sent) || 0).toLocaleString() + ' sent', null],
        [(d.messages_errors || 0) + ' errors',                      errColor],
    ];
    var labels = ['Status', 'Broker', 'Uptime', 'Messages', 'Errors'];
    labels.forEach(function(lbl, i) { grid.appendChild(mqttStatCell(lbl, stats[i][0], stats[i][1])); });
    if (d.last_error) grid.appendChild(mqttStatCell('Last Error', d.last_error, 'var(--red-500,#f44)'));

    panel.textContent = '';
    panel.appendChild(grid);

    // Embedded broker sub-section
    if (d.embedded_broker && d.embedded_broker.enabled) {
        var eb    = d.embedded_broker;
        var ebC   = eb.running ? 'var(--green-500,#4CAF50)' : 'var(--red-500,#f44)';
        var sep   = document.createElement('div');
        sep.style.cssText = 'margin-top:8px;padding-top:8px;border-top:1px solid rgba(255,255,255,0.07)';
        var secHdr = document.createElement('div');
        secHdr.style.cssText = 'font-size:10px;font-weight:bold;color:var(--text-secondary,#888);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px';
        secHdr.textContent = 'Embedded Broker';
        var ebGrid = document.createElement('div');
        ebGrid.style.cssText = 'display:grid;grid-template-columns:repeat(4,1fr);gap:6px 16px';
        var ebStats = [
            ['Status',  eb.running ? 'Running' : 'Stopped', ebC],
            ['Address', eb.address || '—',                  null],
            ['Clients', String(eb.client_count || 0),       null],
            ['Uptime',  fmtSecs(eb.uptime_seconds),         null],
        ];
        ebStats.forEach(function(s) { ebGrid.appendChild(mqttStatCell(s[0], s[1], s[2])); });
        sep.appendChild(secHdr);
        sep.appendChild(ebGrid);
        panel.appendChild(sep);
    }
}

function refreshMQTTStatus() {
    fetch(<?= json_encode($base_url) ?> + '/api/v1/mqtt/status', {signal: AbortSignal.timeout(5000)})
        .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(function(d) { renderMQTTStatus(d); })
        .catch(function() {
            var panel = document.getElementById('mqtt-status-content');
            if (panel) {
                panel.textContent = 'Unable to reach agent — check that it is running.';
                panel.style.color = 'var(--text-secondary,#888)';
            }
        });
}

function refreshMQTTLog() {
    $.post('/plugins/<?= $plugin ?>/include/exec.php', {action: 'mqtt_log'}, function(data) {
        if (data && data.log !== undefined) {
            var el = document.getElementById('mqtt-log-content');
            // ansiToHtml escapes all HTML entities before injecting safe color spans — same pattern as main log
            if (el) el.innerHTML = ansiToHtml(data.log);
        }
    }, 'json');
}

