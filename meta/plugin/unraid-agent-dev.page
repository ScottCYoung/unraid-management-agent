.uma-collector-label { min-width: 110px; font-size: 12px; }
.uma-collector-select { width: 110px; padding: 2px 4px; font-size: 11px; border: 1px solid var(--input-border-color,#555); border-radius: 3px; background: var(--input-bg-color,transparent); color: var(--text-color,inherit); }
.uma-collector-select:disabled { opacity: 0.35; }
