// ── Log refresh ───────────────────────────────────────────────────────────
// ANSI-to-HTML: escapes all user content first, then only injects hardcoded color spans
var ansiColors = {'31':'#f44','32':'#4CAF50','33':'#ff8c00','34':'#6cf','35':'#c084fc','36':'#67e8f9'};
function ansiToHtml(text) {
    var safe = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return safe.replace(/\x1b\[([0-9;]*)m/g, function(_, code) {
        if (code === '0' || code === '') return '</span>';
        return ansiColors[code] ? '<span style="color:'+ansiColors[code]+'">' : '';
    });
}
function refreshLog() {
    $.post('/plugins/<?= $plugin ?>/include/exec.php', {action:'log'}, function(data) {
        if (data && data.log) {
            var el = document.getElementById('uma-log-content');
            var wasAtBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 30;
            // Safe: ansiToHtml escapes HTML entities before inserting color spans
            el.innerHTML = ansiToHtml(data.log);
            if (wasAtBottom) el.scrollTop = el.scrollHeight;
        }
    }, 'json');
}

// ── Server clock + auto-refresh ──────────────────────────────────────────
(function() {
    // Initialize from server time embedded in PHP, tick locally
    var serverEpoch = <?= time() ?>;
    var loadedAt = Math.floor(Date.now() / 1000);

    setInterval(function() {
        var elapsed = Math.floor(Date.now() / 1000) - loadedAt;
        var now = new Date((serverEpoch + elapsed) * 1000);
        var ts = now.getFullYear() + '/' +
            String(now.getMonth()+1).padStart(2,'0') + '/' +
            String(now.getDate()).padStart(2,'0') + ' ' +
            String(now.getHours()).padStart(2,'0') + ':' +
            String(now.getMinutes()).padStart(2,'0') + ':' +
            String(now.getSeconds()).padStart(2,'0');
        var el = document.getElementById('uma-server-clock');
        if (el) el.textContent = 'Server: ' + ts;

        // Tick uptime display
        var up = document.getElementById('uma-uptime');
        if (up) {
            var baseSecs = parseInt(up.dataset.secs) || 0;
            if (baseSecs > 0) {
                var total = baseSecs + elapsed;
                var d = Math.floor(total / 86400);
                var h = Math.floor((total % 86400) / 3600);
                var m = Math.floor((total % 3600) / 60);
                up.textContent = (d > 0 ? d + 'd ' : '') + h + 'h ' + m + 'm';
            }
        }
    }, 1000);

    // Auto-refresh log every 10s when checkbox is checked and Dashboard tab is active
    setInterval(function() {
        var cb = document.getElementById('uma-log-auto');
        var panel = document.getElementById('tab-dashboard');
        if (cb && cb.checked && panel && panel.classList.contains('active')) {
            refreshLog();
        }
    }, 10000);
})();

// ── Collector defaults ──────────────────────────────────────────────────────
// Used by Apply Defaults button and to restore intervals when re-enabling a toggle.
var recommendedDefaults = {
    system:     {enabled: true,  interval: '30'},
    array:      {enabled: true,  interval: '60'},
    disk:       {enabled: true,  interval: '300'},
    network:    {enabled: true,  interval: '30'},
    docker:     {enabled: true,  interval: '30'},
    vm:         {enabled: true,  interval: '60'},
    gpu:        {enabled: false, interval: '60'},
    ups:        {enabled: false, interval: '30'},
    nut:        {enabled: false, interval: '60'},
    hardware:   {enabled: true,  interval: '3600'},
    shares:     {enabled: true,  interval: '300'},
    zfs:        {enabled: false, interval: '300'},
    unassigned: {enabled: true,  interval: '300'},
};
var internalDefaults = {
    INTERVAL_NOTIFICATION: '30',
    INTERVAL_REGISTRATION: '3600',
    INTERVAL_FAN_CONTROL:  '10',
    INTERVAL_TUNING:       '300',
};

function applyCollectorDefaults() {
    document.querySelectorAll('.collector-toggle').forEach(function(cb) {
        var def = recommendedDefaults[cb.dataset.collector];
        if (!def) return;
        var sel = cb.closest('.uma-collector-row').querySelector('select');
        cb.checked = def.enabled;
        if (sel) { sel.disabled = !def.enabled; sel.value = def.enabled ? def.interval : '0'; }
    });
    Object.keys(internalDefaults).forEach(function(name) {
        var sel = document.querySelector('select[name="' + name + '"]');
        if (sel) sel.value = internalDefaults[name];
    });
    document.getElementById('disable_all_cb').checked = false;
    rebuildDisableCollectors();
    $('input[name="#apply"]').prop('disabled', false);
}

function toggleDisableAll(cb) {
    if (cb.checked) {
        // Save current state then disable everything
        document.querySelectorAll('.collector-toggle').forEach(function(toggle) {
            var sel = toggle.closest('.uma-collector-row').querySelector('select');
            toggle.dataset.savedChecked   = toggle.checked ? '1' : '0';
            toggle.dataset.savedInterval  = sel ? sel.value : '0';
            toggle.checked = false;
            if (sel) { sel.disabled = true; sel.value = '0'; }
        });
    } else {
        // Restore saved state (falls back to recommended defaults)
        document.querySelectorAll('.collector-toggle').forEach(function(toggle) {
            var def = recommendedDefaults[toggle.dataset.collector] || {enabled: true, interval: '60'};
            var wasChecked   = toggle.dataset.savedChecked !== undefined ? toggle.dataset.savedChecked === '1' : def.enabled;
            var wasInterval  = toggle.dataset.savedInterval || def.interval;
            var sel = toggle.closest('.uma-collector-row').querySelector('select');
            toggle.checked = wasChecked;
            if (sel) { sel.disabled = !wasChecked; sel.value = wasChecked ? wasInterval : '0'; }
        });
    }
    rebuildDisableCollectors();
    $('input[name="#apply"]').prop('disabled', false);
}

// ── Init ───────────────────────────────────────────────────────────────────
$(function() {
    // Reflect Disable All slider if all collector toggles are off on load
    var allOff = Array.from(document.querySelectorAll('.collector-toggle')).every(function(cb) { return !cb.checked; });
    if (allOff) document.getElementById('disable_all_cb').checked = true;

    // Toggle unchecked → disable select + set interval to 0
    // Toggle checked → enable select + set interval to recommended default if it was 0
    document.querySelectorAll('.collector-toggle').forEach(function(cb) {
        cb.addEventListener('change', function() {
            var sel = this.closest('.uma-collector-row').querySelector('select');
            if (sel) {
                sel.disabled = !this.checked;
                if (!this.checked) {
                    sel.value = '0';
                } else if (sel.value === '0') {
                    var def = recommendedDefaults[this.dataset.collector];
                    sel.value = (def && def.interval) ? def.interval : '60';
                }
            }
            rebuildDisableCollectors();
            $('input[name="#apply"]').prop('disabled', false);
        });
    });
    // Interval dropdown changed to 0 → uncheck toggle; changed from 0 → check toggle
    document.querySelectorAll('.uma-collector-select').forEach(function(sel) {
        sel.addEventListener('change', function() {
            var row = this.closest('.uma-collector-row');
            var cb = row ? row.querySelector('.collector-toggle') : null;
            if (cb) {
                if (this.value === '0' && cb.checked) {
                    cb.checked = false;
                    this.disabled = true;
                } else if (this.value !== '0' && !cb.checked) {
                    cb.checked = true;
                    this.disabled = false;
                }
                rebuildDisableCollectors();
            }
            $('input[name="#apply"]').prop('disabled', false);
        });
    });
    $('#agentConfigForm').on('change input', 'input:not(.collector-toggle), select:not(.uma-collector-select)', function() {
        $('input[name="#apply"]').prop('disabled', false);
    });
});
</script>
